<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:padding="24dp">

    <ImageView
        android:id="@+id/q3e_loading_artwork"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="36dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/loading_preparing_game"
        android:scaleType="fitCenter"
        android:src="@drawable/luna_splash" />

    <TextView
        android:id="@+id/q3e_loading_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/q3e_loading_artwork"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="Luna Game 3D"
        android:textColor="#FFFFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/q3e_loading_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/q3e_loading_title"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="#FFE0E6FF"
        android:textSize="15sp" />

    <ProgressBar
        android:id="@+id/q3e_loading_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/q3e_loading_status"
        android:layout_marginTop="18dp"
        android:max="100"
        android:progress="10"
        android:progressTint="#FF7EA6FF"
        android:secondaryProgressTint="#FF384C77" />

</RelativeLayout>
